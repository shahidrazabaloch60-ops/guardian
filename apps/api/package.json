    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^14.1.0",
    "firebase-functions": "^7.2.5",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jose": "4",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
